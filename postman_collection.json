    {
      "name": "Security Check",
      "item": [
        {
          "name": "6. Static File Access (Blocked)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Access should be denied without token\", function () {",
                  "    pm.expect(pm.response.code).to.not.equal(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/uploads/fatture/fattura-1768565222480-560223961.pdf"
          }
        }
      ]
